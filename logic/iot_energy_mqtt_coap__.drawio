        <mxCell id="JIawFKVB7-rXlWrrBtZz-24" parent="1" style="html=1;rounded=1;arcSize=6;fillColor=#F1EFE8;strokeColor=#5F5E5A;fontColor=#444441;fontSize=10;align=left;verticalAlign=middle;spacingLeft=14;spacingTop=6;" value="&lt;b&gt;Payload examples&lt;/b&gt;&lt;br&gt;MQTT  energy/solar/1/telemetry   →  {&quot;W&quot;:1240, &quot;V&quot;:48.2, &quot;I&quot;:25.8, &quot;irr&quot;:820, &quot;t&quot;:38.1, &quot;ts&quot;:1747734000}&lt;br&gt;MQTT  energy/load/1/telemetry    →  {&quot;W&quot;:3400, &quot;ts&quot;:1747734000}&lt;br&gt;CoAP  POST /energy/telemetry     →  CBOR {src:&quot;load/1&quot;, W:3400, ts:1747734000}&lt;br&gt;CoAP  PUT  /energy/actuator/cmd  →  CBOR {target:&quot;engine/1&quot;, action:&quot;start&quot;, setpoint_W:2000}&lt;div&gt;MQTT  energy/solar/1/cmd  →  {&quot;relay&quot;:&quot;off&quot;, &quot;reason&quot;:&quot;battery_full&quot;, &quot;ts&quot;:...}&lt;/div&gt;" vertex="1">
